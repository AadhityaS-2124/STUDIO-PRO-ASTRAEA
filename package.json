{
  "name": "video-editor",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run dev:electron",
    "dev:browser": "vite",
    "build": "vite build && node build-preload.js",
    "build:preload": "node build-preload.js",
    "start": "electron .",
    "electron:dev": "node build-preload.js && cross-env NODE_ENV=development electron . --remote-debugging-port=9222",
    "no-browser": "node no-browser.js",
    "dev:electron": "concurrently --kill-others \"vite build --mode development --watch\" \"wait-on --timeout 60000 dist/renderer/index.html && npm run electron:dev\""
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "electron": "^42.4.1",
    "konva": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vite-plugin-electron": "^0.11.2",
    "wait-on": "^7.2.0"
  },
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/": [
        "./src/"
      ]
    },
    "types": [
      "vite/client",
      "node"
    ]
  }
}
